/**
 * Sajal Baruah Portfolio Interactive Controller Engine
 * Managed seamlessly for execution on GitHub Pages environment
 */

document.addEventListener("DOMContentLoaded", () => {
    initMobileNav();
    initSmoothScrolling();
    initScrollSkillsObserver();
    initActiveNavHighlight();
});

/**
 * Handles Responsive Mobile Navigation Toggle Logic
 */
function initMobileNav() {
    const mobileMenuBtn = document.getElementById("mobile-menu");
    const navLinksList = document.querySelector(".nav-links");

    mobileMenuBtn.addEventListener("click", () => {
        navLinksList.classList.toggle("active");
        
        // Swap icon between bars and close state
        const icon = mobileMenuBtn.querySelector("i");
        if (navLinksList.classList.contains("active")) {
            icon.className = "fa-solid fa-xmark";
        } else {
            icon.className = "fa-solid fa-bars";
        }
    });

    // Automatically collapse mobile menu when clean link item is selected
    document.querySelectorAll(".nav-link").forEach(link => {
        link.addEventListener("click", () => {
            if (navLinksList.classList.contains("active")) {
                navLinksList.classList.remove("active");
                mobileMenuBtn.querySelector("i").className = "fa-solid fa-bars";
            }
        });
    });
}

/**
 * Custom High Performance Smooth Scrolling Navigation Framework
 */
function initSmoothScrolling() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            const targetElement = document.querySelector(targetId);
            
            if (targetElement) {
                // Header offset margin calibration
                const headerOffset = 90;
                const elementPosition = targetElement.getBoundingClientRect().top;
                const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                window.scrollTo({
                    top: offsetPosition,
                    behavior: 'smooth'
                });
            }
        });
    });
}

/**
 * Intersection Observer Implementation for Skill Bar Dynamic Progression Scaling
 */
function initScrollSkillsObserver() {
    const skillsSection = document.getElementById("skills");
    const progressBars = document.querySelectorAll(".progress-bar");

    const observerOptions = {
        root: null, // Default viewport tracking
        threshold: 0.25 // Trigger when 25% of container element becomes visible
    };

    const skillsObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                // Load and animate progress values safely
                progressBars.forEach(bar => {
                    const TargetPercentage = bar.getAttribute("data-progress");
                    bar.style.width = TargetPercentage;
                });
                // Unobserve to maintain persistent animation states without reprocessing
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    if (skillsSection) {
        skillsObserver.observe(skillsSection);
    }
}

/**
 * Handles Active Nav State Re-evaluation based on Scroll Position Coordinates
 */
function initActiveNavHighlight() {
    const sections = document.querySelectorAll("section");
    const navLinks = document.querySelectorAll(".nav-link");

    window.addEventListener("scroll", () => {
        let currentSectionId = "";
        const scrollPosition = window.scrollY + 120; // Anchor offset boundary

        sections.forEach(section => {
            const sectionTop = section.offsetTop;
            const sectionHeight = section.offsetHeight;

            if (scrollPosition >= sectionTop && scrollPosition < (sectionTop + sectionHeight)) {
                currentSectionId = section.getAttribute("id");
            }
        });

        navLinks.forEach(link => {
            link.classList.remove("active");
            if (link.getAttribute("href") === `#${currentSectionId}`) {
                link.classList.add("active");
            }
        });
    });
}
